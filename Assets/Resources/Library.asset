    - name: 'Chapter 2: She''s My Responsibility'
      fileUrl: https://infernalfury270.github.io/toranoko/read/2_2.pdf
      dateAdded: 27/10/25
    - name: 'Chapter 3: Sharing The Burden'
      fileUrl: https://infernalfury270.github.io/toranoko/read/2_3.pdf
      dateAdded: 1/1/26
    - name: 'Chapter 4: Do The Right Thing'
      fileUrl: https://infernalfury270.github.io/toranoko/read/2_4.pdf
      dateAdded: 1/1/26
    - name: 'Chapter 5: I Want To See You'
      fileUrl: https://infernalfury270.github.io/toranoko/read/2_5.pdf
      dateAdded: 16/2/26
    - name: 'Chapter 6: Our Path Forward'
      fileUrl: https://infernalfury270.github.io/toranoko/read/2_6.pdf
